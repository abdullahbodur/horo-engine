{
  "appId": "com.horoengine.studio",
  "productName": "Horo Studio",
  "directories": {
    "output": "dist"
  },
  "files": [
    "lib/**/*",
    "scripts/**/*",
    "src-gen/**/*",
    "node_modules/**/*",
    "media/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "engine-runtime",
      "to": "engine-runtime",
      "filter": [
        "**/*"
      ]
    }
  ],
  "mac": {
    "category": "public.app-category.developer-tools",
    "icon": "media/icons/horo-studio.icns"
  },
  "win": {
    "target": "nsis",
    "icon": "media/icons/horo-studio.ico",
    "signAndEditExecutable": false
  },
  "linux": {
    "target": "AppImage",
    "icon": "media/icons/horo-studio.png"
  }
}
