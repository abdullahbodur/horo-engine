{
  "private": true,
  "name": "horo-studio",
  "version": "0.1.0",
  "description": "Horo Studio — IDE shell for Horo Engine, built on Eclipse Theia",
  "main": "scripts/electron-main-wrapper.js",
  "theia": {
    "target": "electron",
    "frontend": {
      "config": {
        "applicationName": "Horo Studio",
        "defaultTheme": "dark",
        "defaultIconTheme": "vs-seti"
      }
    }
  },
  "theiaExtensions": [
    {
      "frontend": "lib/horoFrontendModule"
    }
  ],
  "dependencies": {
    "horo-studio": "file:.",
    "@theia/core": "1.56.0",
    "@theia/editor": "1.56.0",
    "@theia/electron": "1.56.0",
    "@theia/filesystem": "1.56.0",
    "@theia/markers": "1.56.0",
    "@theia/messages": "1.56.0",
    "@theia/monaco": "1.56.0",
    "@theia/navigator": "1.56.0",
    "@theia/outline-view": "1.56.0",
    "@theia/output": "1.56.0",
    "@theia/preferences": "1.56.0",
    "@theia/search-in-workspace": "1.56.0",
    "@theia/terminal": "1.56.0",
    "@theia/workspace": "1.56.0",
    "@vscode/ripgrep": "^1.17.1",
    "node-pty": "^1.1.0"
  },
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@theia/cli": "1.56.0",
    "electron": "30.1.2",
    "electron-builder": "^26.8.1",
    "typescript": "^5.3.0"
  },
  "scripts": {
    "prepare": "tsc -p tsconfig.json",
    "build:ext": "tsc -p tsconfig.json",
    "build": "theia build",
    "build:prod": "theia build --mode production",
    "build:electron": "theia build --app-target=electron --mode development",
    "start": "node scripts/studio-cli.js",
    "start:dev": "theia start --port 3000",
    "start:electron": "node scripts/studio-cli.js --electron",
    "start:electron:keep-layout": "node scripts/studio-cli.js --electron --keep-layout",
    "start:electron:win": "node scripts/studio-cli.js --electron",
    "start:electron:linux": "node scripts/studio-cli.js --electron",
    "studio": "node scripts/studio-cli.js",
    "studio:setup": "node scripts/studio-cli.js --setup",
    "studio:setup-electron": "node scripts/studio-cli.js --setup-electron",
    "studio:setup-electron:auto": "node scripts/studio-cli.js --setup-electron --auto-install-spectre",
    "studio:electron": "node scripts/studio-cli.js --electron",
    "studio:electron:debug": "node scripts/studio-cli.js --electron --debug-logs",
    "package:dir": "node scripts/stage-engine-runtime.js && electron-builder --dir",
    "package": "node scripts/stage-engine-runtime.js && electron-builder --config electron-builder.json",
    "watch": "tsc -p tsconfig.json && theia build --watch --mode development",
    "setup:native": "electron-rebuild -f && node node_modules/@vscode/ripgrep/lib/postinstall.js"
  },
  "theia-extension": "horo-studio",
  "keywords": [],
  "author": "Horo Engine",
  "license": "MIT"
}
