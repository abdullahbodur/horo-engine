{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "14.0"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "HORO_ENGINE_BUILD_TESTS": "ON",
        "HORO_RENDERER": "opengl"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "HORO_ENGINE_BUILD_TESTS": "OFF",
        "HORO_RENDERER": "opengl"
      }
    },
    {
      "name": "debug-msvc",
      "displayName": "Debug (MSVC)",
      "inherits": "base",
      "generator": "Ninja",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "HORO_ENGINE_BUILD_TESTS": "ON",
        "HORO_RENDERER": "opengl",
        "CMAKE_C_COMPILER": "cl",
        "CMAKE_CXX_COMPILER": "cl",
        "CMAKE_MSVC_DEBUG_INFORMATION_FORMAT": "Embedded",
        "CMAKE_EXE_LINKER_FLAGS_DEBUG": "/DEBUG:FASTLINK",
        "CMAKE_SHARED_LINKER_FLAGS_DEBUG": "/DEBUG:FASTLINK",
        "CMAKE_MODULE_LINKER_FLAGS_DEBUG": "/DEBUG:FASTLINK"
      }
    },
    {
      "name": "release-msvc",
      "displayName": "Release (MSVC)",
      "inherits": "debug-msvc",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "HORO_ENGINE_BUILD_TESTS": "OFF",
        "CMAKE_EXE_LINKER_FLAGS_DEBUG": "",
        "CMAKE_SHARED_LINKER_FLAGS_DEBUG": "",
        "CMAKE_MODULE_LINKER_FLAGS_DEBUG": ""
      }
    },
    {
      "name": "coverage",
      "displayName": "Coverage (GCC/Clang, Linux/macOS only)",
      "inherits": "base",
      "condition": {
        "type": "notEquals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "HORO_ENGINE_BUILD_TESTS": "ON",
        "HORO_RENDERER": "opengl",
        "CMAKE_CXX_FLAGS": "--coverage -O0",
        "CMAKE_C_FLAGS": "--coverage -O0",
        "CMAKE_EXE_LINKER_FLAGS": "--coverage"
      }
    },
    {
      "name": "null-renderer",
      "displayName": "Null Renderer (headless)",
      "inherits": "release",
      "cacheVariables": {
        "HORO_RENDERER": "null",
        "HORO_ENGINE_BUILD_TESTS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "jobs": 4
    },
    {
      "name": "release",
      "configurePreset": "release",
      "jobs": 4
    },
    {
      "name": "coverage",
      "configurePreset": "coverage",
      "jobs": 4
    },
    {
      "name": "null-renderer",
      "configurePreset": "null-renderer",
      "jobs": 4
    },
    {
      "name": "debug-msvc",
      "configurePreset": "debug-msvc",
      "jobs": 4
    },
    {
      "name": "release-msvc",
      "configurePreset": "release-msvc",
      "jobs": 4
    }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "filter": { "exclude": { "label": "benchmark" } },
      "output": { "outputOnFailure": true },
      "execution": { "jobs": 4, "timeout": 120, "stopOnFailure": false }
    },
    {
      "name": "null-renderer",
      "configurePreset": "null-renderer",
      "filter": { "exclude": { "label": "benchmark" } },
      "output": { "outputOnFailure": true },
      "execution": { "jobs": 4, "timeout": 120, "stopOnFailure": false }
    },
    {
      "name": "coverage",
      "configurePreset": "coverage",
      "filter": { "exclude": { "label": "benchmark" } },
      "output": { "outputOnFailure": true },
      "execution": { "jobs": 4, "timeout": 120, "stopOnFailure": false }
    },
    {
      "name": "debug-msvc",
      "configurePreset": "debug-msvc",
      "filter": { "exclude": { "label": "benchmark" } },
      "output": { "outputOnFailure": true },
      "execution": { "jobs": 4, "timeout": 120, "stopOnFailure": false }
    },
    {
      "name": "benchmark",
      "configurePreset": "debug",
      "filter": { "include": { "label": "benchmark" } },
      "output": { "outputOnFailure": true },
      "execution": { "jobs": 1, "timeout": 600, "stopOnFailure": true }
    }
  ]
}
