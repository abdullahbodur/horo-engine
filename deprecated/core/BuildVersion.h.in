/** @file BuildVersion.h
 *  @brief Engine version metadata injected at CMake configure time.
 *
 *  This file is generated from core/BuildVersion.h.in by CMake's
 *  configure_file().  Do not edit by hand — the template lives in the
 *  source tree; the generated output resides in the build tree and is
 *  included via the build-include path.
 *
 *  All consumers that need the engine version string should include this
 *  header and call Horo::Build::EngineVersion() instead of relying on the
 *  legacy HORO_ENGINE_VERSION preprocessor macro.
 */
#pragma once

namespace Horo::Build {

/** @brief Returns the engine version string from the project() VERSION field.
 *
 *  Guaranteed to be a null-terminated string literal valid for the lifetime
 *  of the process.  Matches the CMake project version set in the top-level
 *  CMakeLists.txt.
 *
 *  @return Version string (e.g. "0.0.1"). */
constexpr const char* EngineVersion() noexcept {
    return "@HORO_ENGINE_VERSION@";
}

} // namespace Horo::Build
